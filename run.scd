////////////////////////////////////////////////////////////
// Adaptive Temperament — CLEAN BOOT (STABLE)
////////////////////////////////////////////////////////////

(
"AdaptiveTemperament: boot".postln;

////////////////////////////////////////////////////////////
// CLEAN PREVIOUS SESSION
////////////////////////////////////////////////////////////

if(~at.notNil and: { ~at[\system].respondsTo(\shutdown) }) {
    ~at[\system].shutdown;
};

if(~masterLimiter.notNil) {
    ~masterLimiter.free;
    ~masterLimiter = nil;
};

////////////////////////////////////////////////////////////
// SERVER OPTIONS
////////////////////////////////////////////////////////////

s.options.blockSize          = 512;
s.options.hardwareBufferSize = 512;
s.options.memSize            = 8192 * 8;
s.options.numWireBufs        = 128;

////////////////////////////////////////////////////////////
// RESET GLOBAL STATE
////////////////////////////////////////////////////////////

~at = IdentityDictionary.new;

~projectPath = thisProcess.nowExecutingPath.dirname +/+ "";

~loadFile = { |path|
    ("--- Loading: " ++ path).postln;
    (~projectPath ++ path).load;
    ("--- Finished: " ++ path).postln;
};

////////////////////////////////////////////////////////////
// BOOT SERVER IF NEEDED
////////////////////////////////////////////////////////////

if(s.serverRunning.not) {
    s.boot;
};

////////////////////////////////////////////////////////////
// AFTER SERVER READY
////////////////////////////////////////////////////////////

s.waitForBoot({

    "Server ready.".postln;

    //////////////////////////////////////////////////////////
    // LOAD CORE FILES (STRICT ORDER)
    //////////////////////////////////////////////////////////

    ~loadFile.value("core/Voice.scd");
    ~loadFile.value("core/Field.scd");
    ~loadFile.value("core/VoiceManager.scd");
    ~loadFile.value("core/Ear.scd");
    ~loadFile.value("core/ControlLoop.scd");
    ~loadFile.value("core/System.scd");

    //////////////////////////////////////////////////////////
    // LOAD VISUALS (OPTIONAL)
    //////////////////////////////////////////////////////////

    ~loadFile.value("visuals/ETOverlayVisualizer.scd");

    //////////////////////////////////////////////////////////
    // MASTER LIMITER (AT TAIL)
    //////////////////////////////////////////////////////////

    ~masterLimiter = {
        ReplaceOut.ar(
            0,
            Limiter.ar(In.ar(0, 2), 0.9)
        );
    }.play(target: s, addAction: \addToTail);

    //////////////////////////////////////////////////////////
    // BOOT SYSTEM
    //////////////////////////////////////////////////////////

    ~at[\system].boot;

    //////////////////////////////////////////////////////////
    // LOAD MIDI (AFTER SYSTEM EXISTS)
    //////////////////////////////////////////////////////////

    ~loadFile.value("core/Midi.scd");

    "Adaptive Temperament initialized.".postln;

});
)