////////////////////////////////////////////////////////////
// VOICE + POLYPHONIC EAR — CLEAN IMPLEMENTATION
////////////////////////////////////////////////////////////

(
////////////////////////////////////////////////////////////
// ADAPTIVE VOICE — MANIFOLD PROJECTION OSCILLATOR
////////////////////////////////////////////////////////////

SynthDef(\adaptiveVoice, { |freq = 440, amp = 0, gate = 1|

    var f, env, drift;
    var sig;

    ////////////////////////////////////////////////////////////
    // CONTROL SMOOTHING
    ////////////////////////////////////////////////////////////

    freq = Lag.kr(freq.max(20), 0.008);
    amp  = Lag.kr(amp.clip(0, 1), 0.04);

    ////////////////////////////////////////////////////////////
    // ENVELOPE
    ////////////////////////////////////////////////////////////

    env = EnvGen.kr(
        Env.asr(0.003, 1.0, 0.08),
        gate,
        doneAction: 2
    );

    ////////////////////////////////////////////////////////////
    // MICRO DRIFT (VERY SUBTLE)
    ////////////////////////////////////////////////////////////

    drift = LFNoise1.kr(0.2).range(-0.0002, 0.0002);
    f = freq * (1 + drift);

    ////////////////////////////////////////////////////////////
    // CLEAN SINE CORE
    ////////////////////////////////////////////////////////////

    sig = SinOsc.ar(f);

    ////////////////////////////////////////////////////////////
    // VERY LIGHT SOFT SATURATION
    ////////////////////////////////////////////////////////////

    sig = tanh(sig * 1.02);

    ////////////////////////////////////////////////////////////
    // OUTPUT (STEREO DUPLICATE, NO ARTIFICIAL DETUNE)
    ////////////////////////////////////////////////////////////

    Out.ar(0, (sig * amp * env) ! 2);

}).add;


////////////////////////////////////////////////////////////
// POLYPHONIC EAR — LOG BAND + WEIGHTED MULTI-PITCH
////////////////////////////////////////////////////////////

SynthDef(\atEarInput, { |replyRate = 30|

    var in, trig;
    var numBands = 10;
    var minFreq = 60;
    var maxFreq = 4000;

    var freqs, amps;
    var globalAmp;

    ////////////////////////////////////////////////////////////
    // INPUT + CLEANUP
    ////////////////////////////////////////////////////////////

    in = SoundIn.ar(0);
    in = HPF.ar(in, 40);      // remove rumble
    in = LPF.ar(in, 6000);    // remove high junk

    ////////////////////////////////////////////////////////////
    // GLOBAL AMP
    ////////////////////////////////////////////////////////////

    globalAmp = Amplitude.kr(in, 0.05, 0.05);

    trig = Impulse.kr(replyRate);

    ////////////////////////////////////////////////////////////
    // LOG-SPACED BAND ANALYSIS
    ////////////////////////////////////////////////////////////

    freqs = Array.fill(numBands, { |i|

        var frac = i / (numBands - 1);
        var center = minFreq * ((maxFreq / minFreq) ** frac);

        var band, bandAmp, pitch;

        band = BPF.ar(in, center, 0.2);
        bandAmp = Amplitude.kr(band, 0.02, 0.02);

        pitch = Pitch.kr(
            band,
            ampThreshold: 0.02,
            median: 5,
            minFreq: minFreq,
            maxFreq: maxFreq
        )[0];

        // Only return pitch if band energy is meaningful
        Select.kr(bandAmp > 0.005, [0, pitch]);

    });

    ////////////////////////////////////////////////////////////
    // SEND RESULTS
    ////////////////////////////////////////////////////////////

    SendReply.kr(
        trig,
        '/earPeaks',
        freqs ++ [globalAmp]
    );

}).add;

)